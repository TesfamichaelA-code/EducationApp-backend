# Runtime
NODE_ENV=development
PORT=8001

# CORS — comma-separated origins (e.g. https://app.example.com,http://localhost:3000)
FRONTEND_ORIGIN=

# Google Gemini — get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Database (used from Block B onwards)
MONGO_URL=mongodb://localhost:27017
DB_NAME=learndeck

# Auth secrets (generated in Block B)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
